  "layers": [
    {
      "id": "liquidity-financial",
      "label": "Liquidity and financial conditions",
      "indicatorFields": [
        "GM2_YoY",
        "credit_card_delinquency_rate",
        "credit_tightening_pct",
        "fed_funds_rate"
      ],
      "interpretation": "Liquidity support is mixed with the cost and availability of credit; higher GM2 does not automatically mean lower stress.",
      "confidence": "Moderate"
    },
    {
      "id": "physical-energy",
      "label": "Physical energy conditions",
      "indicatorFields": [
        "refinery_utilization_pct",
        "oil_consumption_per_person_mmbtu",
        "CI_zscore",
        "petroleum_production_YoY",
        "petroleum_consumption_YoY"
      ],
      "interpretation": "Supply, demand, inventories, and refinery utilization must confirm one another before physical tightness is inferred.",
      "confidence": "Moderate"
    },
    {
      "id": "energy-affordability",
      "label": "Energy affordability",
      "indicatorFields": [
        "real_WTI_YoY",
        "real_disposable_income_YoY",
        "energy_CPI_YoY",
        "household_energy_expenditure_share",
        "energy_expenditure_share_gdp"
      ],
      "interpretation": "Energy stress depends on costs relative to real household income and economic capacity, not on nominal oil alone.",
      "confidence": "Moderate"
    },
    {
      "id": "production-activity",
      "label": "Production and economic activity",
      "indicatorFields": [
        "Real_GDP_growth",
        "business_investment_YoY",
        "Industrial_production_YoY",
        "real_consumer_spending_YoY",
        "manufacturing_output_YoY"
      ],
      "interpretation": "Production, spending, investment, and GDP indicate whether energy and financial conditions are transmitting into measured activity.",
      "confidence": "Moderate"
    },
    {
      "id": "labour-households",
      "label": "Labour and household conditions",
      "indicatorFields": [
        "consumer_sentiment",
        "average_weekly_hours_YoY",
        "unemployment_rate",
        "real_wage_growth",
        "involuntary_part_time_share",
        "prime_age_employment_rate",
        "temporary_help_YoY",
        "full_time_employment_share"
      ],
      "interpretation": "Hours, job composition, wages, sentiment, and unemployment often move at different stages of household stress.",
      "confidence": "Moderate"
    },
    {
      "id": "food-affordability",
      "label": "Food affordability",
      "indicatorFields": [
        "us_food_cpi_yoy",
