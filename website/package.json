{
  "name": "oil-liquidity-inventory-research-site",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "generate:data": "node scripts/generate-data.mjs",
    "validate:chart-data": "node scripts/validate-chart-data.mjs",
    "predev": "npm run generate:data && npm run validate:chart-data",
    "dev": "vite",
    "prebuild": "npm run generate:data && npm run validate:chart-data",
    "build": "tsc -b && vite build",
    "postbuild": "node scripts/prepare-pages.mjs",
    "build:pages": "npm run build",
    "preview": "vite preview",
    "test": "vitest run"
  },
  "dependencies": {
    "@vitejs/plugin-react": "latest",
    "lucide-react": "latest",
    "react": "latest",
    "react-dom": "latest",
    "react-router-dom": "latest",
    "recharts": "latest"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "autoprefixer": "latest",
    "jsdom": "^29.1.1",
    "postcss": "latest",
    "tailwindcss": "^3.4.17",
    "typescript": "latest",
    "vite": "latest",
    "vitest": "^4.1.10"
  }
}
