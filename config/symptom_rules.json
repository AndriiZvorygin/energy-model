        {"indicator": "CI_zscore", "transformation": "full_history_percentile", "expectedDirection": "low", "group": "inventory", "trendWindow": 3},
        {"indicator": "real_WTI_YoY", "transformation": "full_history_percentile", "expectedDirection": "high", "group": "price", "trendWindow": 3}
      ],
      "confirmingIndicators": [
        {"indicator": "refinery_utilization_pct", "transformation": "full_history_percentile", "expectedDirection": "high", "group": "refining"},
        {"indicator": "petroleum_consumption_YoY", "transformation": "momentum", "expectedDirection": "rising", "group": "demand", "trendWindow": 3}
      ],
      "conflictingIndicators": [
        {"indicator": "petroleum_production_YoY", "transformation": "full_history_percentile", "expectedDirection": "high", "group": "supply"}
      ],
      "persistenceRequirement": 2,
      "minimumCoverage": 0.70,
