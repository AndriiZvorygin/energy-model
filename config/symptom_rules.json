  "settings": {
    "minimumCoverage": 0.70,
    "emergingPersistence": 1,
    "activePersistence": 2,
    "monthlyMaximumAgeMonths": 6,
    "quarterlyMaximumAgeMonths": 9,
    "thresholdSets": {
      "20_80": {"low": 20, "high": 80},
